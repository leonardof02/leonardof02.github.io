---
import MainLayout from "../components/layouts/MainLayout.astro";
import TextLogoXL from "../components/ui/TextLogoXL.astro";

// icons
import BagIcon from "../components/icons/BagIcon.astro";
import YoutubeIcon from "../components/icons/YoutubeIcon.astro";
import ExternalLinkIcon from "../components/icons/ExternalLinkIcon.astro";
import GithubIcon from "../components/icons/tech/GithubIcon.astro";
---

<MainLayout>
  <TextLogoXL />
  <div class="flex flex-col mt-4 gap-4">
    <a
      href="https://www.youtube.com/@leonardof02"
      class="flex items-center justify-center gap-3 p-3 bg-red-600 text-white uppercase rounded-md text-center font-extrabold text-base md:text-xl cursor-pointer hover:brightness-110 hover:-translate-y-1 transition-all"
    >
      <YoutubeIcon width={32} height={32} />
      <span>My YouTube Channel (spanish)</span>
    </a>
    <a
      href="https://leonardof02.github.io/noob-blog/"
      class="flex items-center justify-center gap-3 p-3 bg-orange-400 uppercase rounded-md text-center font-extrabold text-base md:text-xl text-zinc-900 cursor-pointer hover:brightness-110 hover:-translate-y-1 transition-all"
    >
      <ExternalLinkIcon width={32} height={32} />
      <span>Explore Blog (spanish)</span>
    </a>
    <a
      href="/projects"
      class="flex items-center justify-center gap-3 p-3 bg-transparent border border-lime-500 text-lime-500 uppercase rounded-md text-center font-extrabold text-base md:text-xl cursor-pointer hover:brightness-110 hover:bg-lime-950 hover:-translate-y-1 transition-all"
    >
      <BagIcon width={32} height={32} />
      <span>My Projects</span>
    </a>
    <a
    href="https://github.com/leonardof02"
    class="flex items-center justify-center gap-3 p-3 bg-neutral-800 border border-neutral-700 text-neutral-200 uppercase rounded-md text-center font-extrabold text-base md:text-xl cursor-pointer hover:brightness-110 hover:bg-neutral-700 hover:-translate-y-1 transition-all"
  >
    <GithubIcon width={32} height={32} />
    <span>Github</span>
  </a>
  </div>
</MainLayout>
